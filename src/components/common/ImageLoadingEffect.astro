---
import { getImageLoadingEffect } from '../../lib/domain/image-loading-effect-registry';

interface Props {
  effectName: string;
}

const { effectName } = Astro.props;

if (typeof effectName !== 'string' || !effectName.trim()) {
  throw new Error(`Invalid image placeholder effect name: ${String(effectName)}`);
}

const selectedEffect = getImageLoadingEffect(effectName.trim());
---

<div class="fx-root" data-effect-name={selectedEffect.name} aria-hidden="true">
  <div class="fx-svg" set:html={selectedEffect.svg}></div>
  <div class="fx-static" aria-hidden="true"></div>
</div>

<style>
  .fx-root {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .fx-svg,
  .fx-svg :global(svg) {
    width: var(--image-load-effect-size);
    height: var(--image-load-effect-size);
    display: block;
  }

  .fx-static {
    display: none;
    width: var(--image-load-static-dot-size);
    height: var(--image-load-static-dot-size);
    border-radius: 50%;
    background: var(--image-load-static-dot-color);
  }

  .fx-root[data-effect-name^='bars-'] .fx-svg,
  .fx-root[data-effect-name^='bars-'] .fx-svg :global(svg) {
    width: var(--image-load-bars-width);
    height: var(--image-load-bars-height);
  }

  .fx-root[data-effect-name='bars-scale-y'] .fx-svg,
  .fx-root[data-effect-name='bars-scale-y'] .fx-svg :global(svg) {
    width: var(--image-load-bars-width);
    height: var(--image-load-bars-width);
  }

  @media (prefers-reduced-motion: reduce) {
    .fx-svg {
      display: none;
    }

    .fx-static {
      display: block;
    }
  }

  @media (min-width: 767px) {
    .fx-svg,
    .fx-svg :global(svg) {
      width: var(--image-load-effect-size-lg);
      height: var(--image-load-effect-size-lg);
    }

    .fx-root[data-effect-name^='bars-'] .fx-svg,
    .fx-root[data-effect-name^='bars-'] .fx-svg :global(svg) {
      width: var(--image-load-bars-width-lg);
      height: var(--image-load-bars-height-lg);
    }

    .fx-root[data-effect-name='bars-scale-y'] .fx-svg,
    .fx-root[data-effect-name='bars-scale-y'] .fx-svg :global(svg) {
      width: var(--image-load-bars-width-lg);
      height: var(--image-load-bars-width-lg);
    }
  }

  .fx-svg :global(svg) {
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
