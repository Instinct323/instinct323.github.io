---
import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';
import 'swiper/css/effect-coverflow';
import '../../styles/carousel.css';
import DeferredImage from '../common/DeferredImage.astro';
import type { FeaturedSlide, HomepageConfig } from '../../lib/loaders/content-loader';
import { resolveControlImageLoading } from '../../lib/loaders/page-load-orchestrator';

// Contract: Render the full featured-media carousel region used on the home page,
// including slide markup, controls, and client bootstrap hooks.

interface Props {
  slides: FeaturedSlide[];
  settings: HomepageConfig['featuredCarousel'];
  placeholderEffectName: string;
  lazyLoadRuntimePayload: string;
}

const { slides, settings, placeholderEffectName, lazyLoadRuntimePayload } = Astro.props;
const totalSlides = slides.length;
const hasSlides = totalSlides > 0;
const hasMultiSlides = totalSlides > 1;
const showArrows = settings.showNavigationArrows && hasMultiSlides;
const showIndicator = settings.showIndicator && hasMultiSlides;
const showControls = showArrows || showIndicator;
const counterPadLength = Math.max(1, settings.counterPadLength);
const firstProgressWidth = totalSlides > 0 ? (100 / totalSlides) : 100;
const visual = settings.visual;
const slideWidthDesktop = visual.slideWidth.desktop;
const slideWidthTablet = visual.slideWidth.tablet;
const slideWidthMobile = visual.slideWidth.mobile;
const inactiveOpacity = Math.min(1, Math.max(0, visual.inactiveOpacity));
const deferredImageLoading = resolveControlImageLoading('deferred');

const prevIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>`;
const nextIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>`;

---

{hasSlides ? (
  <div
    class="swiper home-carousel"
    data-testid="home-carousel"
    data-counter-pad-length={counterPadLength}
    data-space-between={visual.spaceBetween}
    data-slide-width-desktop={slideWidthDesktop}
    data-slide-width-tablet={slideWidthTablet}
    data-slide-width-mobile={slideWidthMobile}
    data-inactive-opacity={inactiveOpacity}
    aria-label={settings.ariaLabel}
    aria-roledescription="carousel"
    data-carousel-lazy-config={lazyLoadRuntimePayload}
    style={`--carousel-slide-width-desktop: ${slideWidthDesktop}; --carousel-slide-width-tablet: ${slideWidthTablet}; --carousel-slide-width-mobile: ${slideWidthMobile}; --carousel-inactive-opacity: ${inactiveOpacity};`}
  >
    <div class="swiper-wrapper" data-testid="carousel-viewport">
      {slides.map((slide, index) => (
        <div
          class="swiper-slide"
          data-testid={`carousel-slide-${index}`}
          aria-label={`Slide ${index + 1} of ${totalSlides}`}
        >
          <div class="slide-media-frame image-deferred-frame">
            <DeferredImage
              group="home-carousel-image"
              placeholderEffectName={placeholderEffectName}
            >
              <img
                src={slide.src}
                srcset={slide.srcset}
                sizes={slide.sizes}
                alt={slide.alt}
                width={slide.width}
                height={slide.height}
                loading={deferredImageLoading.loading}
                decoding={deferredImageLoading.decoding}
                fetchpriority={deferredImageLoading.fetchPriority}
              />
            </DeferredImage>
          </div>
        </div>
      ))}
    </div>

    {showControls && (
      <>
        {showArrows && (
          <>
            {/* Floating Minimalist Arrows */}
            <button
              type="button"
              class="nav-arrow nav-arrow--prev"
              data-testid="carousel-prev"
              aria-label={settings.prevButtonAriaLabel}
            >
              <Fragment set:html={prevIcon} />
            </button>

            <button
              type="button"
              class="nav-arrow nav-arrow--next"
              data-testid="carousel-next"
              aria-label={settings.nextButtonAriaLabel}
            >
              <Fragment set:html={nextIcon} />
            </button>
          </>
        )}

        {showIndicator && (
          <div class="elegant-indicator">
            <div class="indicator-counter">
              <span class="count-current">{String(1).padStart(counterPadLength, '0')}</span>
              <span class="count-separator"></span>
              <span class="count-total">{totalSlides.toString().padStart(counterPadLength, '0')}</span>
            </div>
            <div class="indicator-progress">
               <div class="indicator-progress-fill" style={`width: ${firstProgressWidth}%`} />
            </div>
          </div>
        )}
      </>
    )}
  </div>
) : (
  <div class="swiper-empty" data-testid="home-coverflow-empty">
    <p>{settings.emptyText}</p>
  </div>
)}

{hasSlides && <script>
  import { initHomeCarouselDeferredMounts } from '../../lib/runtime/deferred-mount-bootstrap';
  initHomeCarouselDeferredMounts();
</script>}

{hasMultiSlides && <script>
  import { initCarouselWithPrewarm } from '../../lib/runtime/carousel-init';

  const carouselRoot = document.querySelector('.home-carousel');
  if (carouselRoot instanceof HTMLElement) {
    initCarouselWithPrewarm(carouselRoot);
  }
</script>}


