---
// GalleryImage.astro - Individual image card component
// Image strategy: keep astro:assets <Image> for gallery cards to use build-time transforms and responsive variants.

import { Image } from 'astro:assets';
import DeferredMount from '../common/DeferredMount.astro';
import ImageLoadingEffect from '../common/ImageLoadingEffect.astro';

import type { MediaImage } from '../../lib/content-loader';

interface Props {
  image: MediaImage;
  placeholderEffectName: string;
}

const {
  image,
  placeholderEffectName,
} = Astro.props;
const aspectRatio = `${image.width} / ${image.height}`;
---

<article data-testid="gallery-image" class="image-card">
  <div
    class="image-wrapper"
    style={`--aspect-ratio: ${aspectRatio};`}
    data-aspect-ratio={aspectRatio}
  >
    <DeferredMount group="gallery-image">
      <div slot="placeholder" class="image-lazy-placeholder" aria-hidden="true">
        <ImageLoadingEffect effectName={placeholderEffectName} />
      </div>
      <Image
        src={image.src}
        alt={image.alt}
        width={image.width}
        height={image.height}
        widths={image.responsive.widths}
        sizes={image.responsive.sizes}
        format={image.responsive.format}
        quality={image.responsive.quality}
        loading="lazy"
        decoding="async"
      />
    </DeferredMount>
  </div>
  {image.caption && <p class="caption">{image.caption}</p>}
</article>

<style>
  .image-card {
    background: var(--image-load-card-bg);
    border-radius: var(--image-load-card-radius);
    overflow: hidden;
    border: 1px solid var(--image-load-card-border);
    transition:
      box-shadow var(--motion-duration-md) var(--motion-ease-smooth),
      transform var(--motion-duration-md) var(--motion-ease-smooth);
  }

  .image-card:hover {
    box-shadow: var(--image-load-card-hover-shadow);
    transform: var(--image-load-card-hover-lift);
  }

  .image-wrapper {
    aspect-ratio: var(--aspect-ratio);
    overflow: hidden;
    position: relative;
    background: var(--image-load-placeholder-bg);
  }

  .image-wrapper :global(.deferred-mount) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .image-wrapper :global([data-deferred-host]) {
    width: 100%;
    height: 100%;
  }

  .image-wrapper :global(.image-lazy-placeholder) {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background: var(--image-load-placeholder-bg);
  }

  @media (prefers-reduced-motion: reduce) {
    .image-card {
      transition: none;
    }
  }

  .image-wrapper :global(img) {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .caption {
    margin: 0;
    padding: var(--image-load-caption-padding);
    color: var(--text-muted);
    font-size: var(--image-load-caption-font-size);
    background: var(--image-load-caption-bg);
    line-height: 1.4;
  }

</style>
