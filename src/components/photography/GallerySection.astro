---
import GallerySectionContent from './GallerySectionContent.astro';
import type { GridColumns, MediaAlbum, MediaImage } from '../../lib/content-loader';

interface Props {
  sectionId: string;
  sectionTitle: string;
  images: MediaImage[];
  sectionTestId: string;
  albums?: MediaAlbum[];
  columns: GridColumns;
  gap: string;
  placeholderEffectName: string;
}

const {
  sectionId,
  sectionTitle,
  images,
  sectionTestId,
  albums,
  columns,
  gap,
  placeholderEffectName,
} = Astro.props;
---

<section
  id={sectionId}
  data-testid={sectionTestId}
  class="gallery-section card"
>
  <h2 class="section-title" data-testid={`gallery-section-title-${sectionId}`}>{sectionTitle}</h2>

  <GallerySectionContent
    sectionTitle={sectionTitle}
    images={images}
    albums={albums}
    columns={columns}
    gap={gap}
    placeholderEffectName={placeholderEffectName}
  />
</section>

<style>
  .gallery-section {
    margin-bottom: var(--space-section-md);
    scroll-margin-top: var(--section-anchor-scroll-margin);
  }

  .section-title {
    margin: 0 0 var(--space-stack-md) 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gallery-title-color, #102a43);
    letter-spacing: -0.015em;
  }

  @media (max-width: 767px) {
    .gallery-section {
      margin-bottom: var(--space-section-sm);
    }

    .section-title {
      font-size: 1.125rem;
    }
  }
</style>
