---
import GallerySectionContent from './GallerySectionContent.astro';
import type { GridColumns, MediaAlbum, MediaImage } from '../../lib/loaders/content-loader';

interface Props {
  sectionId: string;
  sectionTitle: string;
  images: MediaImage[];
  sectionTestId: string;
  albums?: MediaAlbum[];
  columns: GridColumns;
  gap: string;
  placeholderEffectName: string;
}

const {
  sectionId,
  sectionTitle,
  images,
  sectionTestId,
  albums,
  columns,
  gap,
  placeholderEffectName,
} = Astro.props;
---

<section
  id={sectionId}
  data-testid={sectionTestId}
  class="gallery-section card"
>
  <h2 class="section-title" data-testid={`gallery-section-title-${sectionId}`}>{sectionTitle}</h2>

  <GallerySectionContent
    sectionTitle={sectionTitle}
    images={images}
    albums={albums}
    columns={columns}
    gap={gap}
    placeholderEffectName={placeholderEffectName}
  />
</section>

<style>
  .gallery-section {
    /* Remove margin-bottom; spacing is handled by .gallery-container gap */
    scroll-margin-top: var(--photo-scroll-offset);
  }

  /* First section has no top spacing (nav padding handles it) */
  .gallery-section:not(:first-child) {
    margin-top: var(--photo-gap-section);
  }

  .section-title {
    margin: 0 0 var(--space-stack-md) 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gallery-title-color, #102a43);
    letter-spacing: -0.015em;
  }

  @media (max-width: 767px) {
    .section-title {
      font-size: 1.125rem;
    }
  }
</style>
