---
import GalleryGrid from './GalleryGrid.astro';
import type { GridColumns, MediaAlbum, MediaImage } from '../../lib/loaders/content-loader';

interface Props {
  sectionTitle: string;
  images: MediaImage[];
  albums?: MediaAlbum[];
  columns: GridColumns;
  gap: string;
  placeholderEffectName: string;
}

const {
  sectionTitle,
  images,
  albums,
  columns,
  gap,
  placeholderEffectName,
} = Astro.props;

const hasAlbums = (albums?.length ?? 0) > 0;
const hasDirectImages = images.length > 0;
---

{hasAlbums && albums?.map((album) => (
  <div class="album-subsection" data-testid={`album-${album.id}`}>
    <h3 class="album-title">{album.title}</h3>
    <GalleryGrid
      images={album.images}
      emptyLabel={album.title}
      columns={columns}
      gap={gap}
      placeholderEffectName={placeholderEffectName}
    />
  </div>
))}

{hasDirectImages && (
  <GalleryGrid
    images={images}
    emptyLabel={sectionTitle}
    columns={columns}
    gap={gap}
    placeholderEffectName={placeholderEffectName}
  />
)}

<style>
  .album-subsection {
    margin-bottom: var(--space-stack-lg);
  }

  .album-subsection:last-child {
    margin-bottom: 0;
  }

  .album-title {
    margin: 0 0 var(--space-stack-sm) 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--gallery-subtitle-color, #243b53);
    letter-spacing: -0.005em;
  }

  @media (max-width: 767px) {
    .album-title {
      font-size: 0.9375rem;
    }
  }
</style>
