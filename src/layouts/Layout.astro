---
import { getImage } from 'astro:assets';
import { backgroundDesktopSource, backgroundMobileSource } from '../lib/loaders/content-paths';
import LayoutHead from '../components/layout/LayoutHead.astro';
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import { loadEffectsConfig, loadMediaConfig, loadSiteMetadata } from '../lib/loaders/config-loader';
import { buildShellStyle, type LayoutProps } from '../lib/domain/layout-shell';
import {
  RESPONSIVE_VIEWPORT_WIDTHS,
  assertMediaConfigShape,
} from '../lib/loaders/media-loader-core';
import { orchestratePageLoad } from '../lib/loaders/page-load-orchestrator';
import {
  LAYOUT_MOBILE_HEIGHT,
  LAYOUT_DESKTOP_HEIGHT,
  selectBackgroundWidth,
  inferCoverWidth,
} from '../lib/utils/layout-utils';
import { assertString } from '../lib/utils/assertions';
import '../styles/layout-shell.css';
import '../styles/tokens.css';

const {
  title,
  description,
  type = 'website',
  noindex = false,
  shell = 'default',
  contentWidth = 'standard',
} = Astro.props as LayoutProps;

const BACKGROUND_MOBILE_ASPECT_RATIO = backgroundMobileSource.width / backgroundMobileSource.height;
const BACKGROUND_DESKTOP_ASPECT_RATIO = backgroundDesktopSource.width / backgroundDesktopSource.height;

type BackgroundVariantKey = 'mobile' | 'desktop';

interface BackgroundVariantInput {
  key: BackgroundVariantKey;
  source: typeof backgroundMobileSource;
  inferredWidth: number;
  aspectRatio: number;
}

const mobileInferredWidth = inferCoverWidth(
  RESPONSIVE_VIEWPORT_WIDTHS.mobile,
  LAYOUT_MOBILE_HEIGHT,
  BACKGROUND_MOBILE_ASPECT_RATIO,
);
const desktopInferredWidth = inferCoverWidth(
  RESPONSIVE_VIEWPORT_WIDTHS.desktop,
  LAYOUT_DESKTOP_HEIGHT,
  BACKGROUND_DESKTOP_ASPECT_RATIO,
);

type LayoutFrameData = {
  siteMetadata: Awaited<ReturnType<typeof loadSiteMetadata>>;
  mediaConfig: Awaited<ReturnType<typeof loadMediaConfig>>;
  effectsConfig: Awaited<ReturnType<typeof loadEffectsConfig>>;
};

type LayoutBackgroundData = {
  backgroundMobile: Awaited<ReturnType<typeof getImage>>;
  backgroundDesktop: Awaited<ReturnType<typeof getImage>>;
};

const layoutLoad = await orchestratePageLoad<LayoutFrameData, LayoutBackgroundData>({
  frame: async () => {
    const [siteMetadata, mediaConfig, effectsConfig] = await Promise.all([
      loadSiteMetadata(),
      loadMediaConfig(),
      loadEffectsConfig(),
    ]);

    assertMediaConfigShape(mediaConfig);

    return {
      siteMetadata,
      mediaConfig,
      effectsConfig,
    };
  },
  background: async ({ frame }) => {
    const backgroundQuality = frame.mediaConfig.image.quality;
    const backgroundWidths = frame.mediaConfig.image.widths.high;
    const backgroundDprScale = frame.mediaConfig.image.dprScale.medium;
    const variants: BackgroundVariantInput[] = [
      {
        key: 'mobile',
        source: backgroundMobileSource,
        inferredWidth: mobileInferredWidth,
        aspectRatio: BACKGROUND_MOBILE_ASPECT_RATIO,
      },
      {
        key: 'desktop',
        source: backgroundDesktopSource,
        inferredWidth: desktopInferredWidth,
        aspectRatio: BACKGROUND_DESKTOP_ASPECT_RATIO,
      },
    ];

    const backgroundVariantEntries = await Promise.all(variants.map(async (variant) => {
      const width = selectBackgroundWidth(
        backgroundWidths,
        variant.inferredWidth,
        backgroundDprScale,
        `${variant.key}.medium`,
        variant.source.width,
      );

      const image = await getImage({
        src: variant.source,
        width,
        height: Math.ceil(width / variant.aspectRatio),
        fit: 'cover',
        position: 'center',
        format: 'webp',
        quality: backgroundQuality,
      });

      return [variant.key, image] as const;
    }));

    const backgroundByVariant = Object.fromEntries(backgroundVariantEntries) as Record<
      BackgroundVariantKey,
      Awaited<ReturnType<typeof getImage>>
    >;

    return {
      backgroundMobile: backgroundByVariant.mobile,
      backgroundDesktop: backgroundByVariant.desktop,
    };
  },
});

const {
  siteMetadata,
  effectsConfig,
} = layoutLoad.frame;
const { backgroundMobile, backgroundDesktop } = layoutLoad.background;

// Fail-fast: Astro.site must be configured in astro.config.ts
if (!Astro.site) {
  throw new Error('Astro.site is not configured. Please set site in astro.config.ts.');
}
const siteUrl = Astro.site;

const shellBackgroundPayload = JSON.stringify({
  mobileSrc: backgroundMobile.src,
  desktopSrc: backgroundDesktop.src,
});

// Fail-fast: title and description should be provided by pages or site config
const resolvedTitle = title !== undefined ? title : assertString(siteMetadata.defaultTitle, 'siteMetadata.defaultTitle');
const resolvedDescription = description !== undefined ? description : assertString(siteMetadata.defaultDescription, 'siteMetadata.defaultDescription');

const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const sitemapUrl = new URL('/sitemap-index.xml', siteUrl).toString();
const shellStyle = buildShellStyle(shell, contentWidth);
const starfieldConfig = effectsConfig.starfield;
---

<!doctype html>
<html lang="en">
  <head>
    <LayoutHead
      generator={Astro.generator}
      title={resolvedTitle}
      description={resolvedDescription}
      canonicalUrl={canonicalUrl}
      sitemapUrl={sitemapUrl}
      type={type}
      noindex={noindex}
    />
  </head>
  <body data-shell={shell} style={shellStyle}>
    <div
      class="site-frame"
      aria-hidden="true"
      data-shell-background={shellBackgroundPayload}
    >
      <canvas class="site-stars-background"></canvas>
      <canvas
        class="site-stars"
        data-testid="site-stars"
        data-starfield={JSON.stringify(starfieldConfig)}
      ></canvas>
    </div>
    <main class="site-shell" data-shell={shell} data-testid="site-shell">
      <Header />
      <slot />
      <Footer />
    </main>
    <script>
      import { initLayout } from '../lib/runtime/layout-runtime';

      initLayout();
    </script>
  </body>
</html>
