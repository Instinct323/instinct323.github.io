---
import Layout from '../layouts/Layout.astro';
import AvatarSection from '../components/about/AvatarSection.astro';
import ContentSection from '../components/about/ContentSection.astro';
import ProfileCard from '../components/about/ProfileCard.astro';
import PublicationsSection from '../components/about/PublicationsSection.astro';
import { loadAboutAvatarImage, loadAboutPageFrame } from '../lib/loaders/content-loader';
import { loadMediaConfig } from '../lib/loaders/config-loader';
import { buildDeferredMountRuntimePayload } from '../lib/runtime/deferred-mount-page';
import { orchestratePageLoad } from '../lib/loaders/page-load-orchestrator';

const aboutLoad = await orchestratePageLoad({
  frame: async () => {
    const [aboutFrame, mediaConfig] = await Promise.all([
      loadAboutPageFrame(),
      loadMediaConfig(),
    ]);

    return {
      ...aboutFrame,
      mediaConfig,
    };
  },
  controls: ({ frame }) => loadAboutAvatarImage(frame.profile),
});

const { introductionHtml, profile, publications, mediaConfig } = aboutLoad.frame;
const avatarImage = aboutLoad.controls;
const avatarPlaceholderEffectName = mediaConfig.image.placeholderEffect;
const avatarLazyRuntimePayload = buildDeferredMountRuntimePayload(mediaConfig.image.lazyLoad, import.meta.env.DEV);

const profileName = profile.facts.find(({ id }) => id === 'name')?.value;
---

<Layout
  shell="about"
  contentWidth="wide"
>
  <section
    class="about-page page-container layout-content-container"
    data-about-avatar-lazy-config={avatarLazyRuntimePayload}
  >
    <div class="about-container">
      <aside class="left-rail">
        <AvatarSection
          avatarImage={avatarImage}
          placeholderEffectName={avatarPlaceholderEffectName}
        />
        <ProfileCard facts={profile.facts} />
      </aside>

      <div class="about-content">
        <ContentSection introductionHtml={introductionHtml} />
        <PublicationsSection publications={publications} highlightAuthor={profileName} />
      </div>
    </div>
  </section>
</Layout>

<script>
  import {
    buildDeferredMountBootstrapOptions,
    initDeferredMountGroupSafely,
  } from '../lib/runtime/deferred-mount-page';

  initDeferredMountGroupSafely(
    buildDeferredMountBootstrapOptions(
      '.about-page[data-about-avatar-lazy-config]',
      'aboutAvatarLazyConfig',
      'about-avatar-image',
    ),
    'about avatar',
  );
</script>

<style>
  .about-page {
    /* Uses .page-container from layout-shell.css for padding */
  }

  .about-container {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .about-page :global(.card) {
    width: 100%;
    box-sizing: border-box;
  }

  .left-rail {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-md);
    position: sticky;
    min-width: 0;
    /* Keep a visible gap so the sticky rail does not visually collide with the header. */
    top: calc(var(--header-height) + var(--space-stack-sm));
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-md);
    min-width: 0; /* Prevent overflow */
  }

  @media (max-width: 767px) {
    .about-container {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .left-rail {
      position: static;
      align-items: stretch;
    }
  }
</style>
