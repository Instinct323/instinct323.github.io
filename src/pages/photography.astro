---
import Layout from '../layouts/Layout.astro';
import GallerySection from '../components/photography/GallerySection.astro';
import { loadMediaTree, loadPhotography } from '../lib/loaders/content-loader';
import { loadMediaConfig } from '../lib/loaders/config-loader';
import { buildDeferredMountRuntimePayload } from '../lib/runtime/deferred-mount-page';
import { orchestratePageLoad } from '../lib/loaders/page-load-orchestrator';

const photographyLoad = await orchestratePageLoad({
  frame: async () => {
    const [mediaTree, photographyConfig, mediaConfig] = await Promise.all([
      loadMediaTree(),
      loadPhotography(),
      loadMediaConfig(),
    ]);

    return {
      mediaTree,
      photographyConfig,
      mediaConfig,
    };
  },
});

const {
  mediaTree,
  photographyConfig,
  mediaConfig,
} = photographyLoad.frame;

const { categories } = mediaTree;
const { grid } = photographyConfig;
const imageConfig = mediaConfig.image;
const galleryLazyRuntimePayload = buildDeferredMountRuntimePayload(imageConfig.lazyLoad, import.meta.env.DEV);
---

<Layout
  shell="photography"
  contentWidth="wide"
>
  <section class="photography-page page-container">
    <nav class="sticky-nav" data-testid="photography-sticky-nav" aria-label="Gallery sections">
      <div class="nav-inner layout-content-container">
        {categories.map((category) => (
          <a
            href={`#${category.id}`}
            class="nav-chip"
            data-testid={`photography-chip-${category.id}`}
          >
            {category.title}
          </a>
        ))}
      </div>
    </nav>

    <div
      class="gallery-container layout-content-container"
      data-gallery-lazy-config={galleryLazyRuntimePayload}
    >
      {categories.map(({ id, images, albums, testId, title }) => (
        <GallerySection
          sectionId={id}
          sectionTitle={title}
          images={images}
          albums={albums}
          sectionTestId={testId}
          columns={grid.columns}
          gap={grid.gap}
          placeholderEffectName={imageConfig.placeholderEffect}
        />
      ))}
    </div>
  </section>
</Layout>

<script>
  import {
    buildDeferredMountBootstrapOptions,
    initDeferredMountGroupSafely,
  } from '../lib/runtime/deferred-mount-page';

  initDeferredMountGroupSafely(
    buildDeferredMountBootstrapOptions(
      '.gallery-container[data-gallery-lazy-config]',
      'galleryLazyConfig',
      'gallery-image',
    ),
    'gallery',
  );
</script>

<style>
  /*
    Photography page spacing system (defined on :root for global access)
    Base gap unit = 1rem:
    - gap-sm: gap between header and nav (sticky position), and gap between nav and section on anchor jump
    - gap-section: space between sections (2 * gap-sm + nav-height) ensures nav fits between sections
  */
  :root {
    --photo-gap-sm: 1rem;
    --photo-nav-height: 2rem;

    /* Anchor scroll offset: header + gap-sm + nav-height + gap-sm */
    /* When jumping to a section, the gap-sm after nav is the visible spacing */
    --photo-scroll-offset: calc(var(--header-height) + var(--photo-gap-sm) + var(--photo-nav-height) + var(--photo-gap-sm));

    /* Section spacing: 2 * gap-sm + nav-height */
    --photo-gap-section: calc(2 * var(--photo-gap-sm) + var(--photo-nav-height));
  }

  .gallery-container {
    /* Ensure last section has enough scroll space at page bottom */
    padding-bottom: var(--photo-gap-section);
  }

  .sticky-nav {
    position: sticky;
    /* Sticky position: header + gap-sm */
    top: calc(var(--header-height) + var(--photo-gap-sm));
    z-index: 10;
    box-sizing: border-box;

    /* Padding bottom creates gap-sm between nav and gallery */
    padding-bottom: var(--photo-gap-sm);
  }

  .nav-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    height: var(--photo-nav-height);
  }

  .nav-chip {
    display: inline-flex;
    align-items: center;
    min-height: var(--photo-nav-height);
    box-sizing: border-box;
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--nav-chip-text);
    text-decoration: none;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--nav-chip-radius);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    transition: 
      background var(--motion-duration-sm) var(--motion-ease-smooth),
      transform var(--motion-duration-sm) var(--motion-ease-smooth);
  }

  .nav-chip:hover {
    background: var(--nav-chip-hover-bg);
    transform: translateY(-1px);
  }

  .nav-chip:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 2px;
  }

  @media (max-width: 767px) {
    .sticky-nav {
      /* Keep same gap-sm on mobile */
      padding-bottom: var(--photo-gap-sm);
    }

    .nav-inner {
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: center;
      gap: 0.5rem;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x proximity;
    }

    .nav-inner::-webkit-scrollbar {
      display: none;
    }

    .nav-chip {
      flex-shrink: 0;
      padding: 0.375rem 0.8125rem;
      font-size: 0.8125rem;
      scroll-snap-align: start;
    }
  }
</style>
