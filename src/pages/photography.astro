---
import Layout from '../layouts/Layout.astro';
import GallerySection from '../components/photography/GallerySection.astro';
import { loadMediaTree, loadPhotography } from '../lib/content-loader';
import { loadMediaConfig } from '../lib/config-loader';

const [mediaTree, photographyConfig, mediaConfig] = await Promise.all([
  loadMediaTree(),
  loadPhotography(),
  loadMediaConfig(),
]);

const { categories } = mediaTree;
const { hero: heroConfig, grid } = photographyConfig;
const imageConfig = mediaConfig.image;
const lazyLoadRuntimeConfig = {
  rootMargin: imageConfig.lazyLoad.rootMargin,
  mountDelayMs: import.meta.env.DEV ? imageConfig.lazyLoad.localDebugDelayMs : 0,
};
const eyebrowText = heroConfig.eyebrow?.trim() ?? '';
const descriptionText = heroConfig.description?.trim() ?? '';
const totalImageCount = categories.reduce((imageCount, category) => {
  const directCount = category.images.length;
  const albumCount = (category.albums ?? []).reduce(
    (albumSum, album) => albumSum + album.images.length,
    0,
  );
  return imageCount + directCount + albumCount;
}, 0);
---

<Layout
  pageKey="photography"
  shell="photography"
  contentWidth="wide"
>
  <section class="photography-page">
    <header class="hero-block" data-testid="photography-hero">
      {eyebrowText && (
        <p class="site-eyebrow hero-eyebrow-accent eyebrow-accent" data-testid="photography-eyebrow">{eyebrowText}</p>
      )}
      <h1 class="site-hero-title hero-title-accent title-accent" data-testid="photography-page-title">{heroConfig.title}</h1>
      <p class="meta-line">{categories.length} categories · {totalImageCount} images</p>
      {descriptionText && (
        <p class="page-description" data-testid="photography-page-description">
          {descriptionText}
        </p>
      )}
    </header>

    <nav class="sticky-nav" data-testid="photography-sticky-nav" aria-label="Gallery sections">
      <div class="nav-inner layout-content-container">
        {categories.map((category) => (
          <a
            href={`#${category.id}`}
            class="nav-chip"
            data-testid={`photography-chip-${category.id}`}
          >
            {category.title}
          </a>
        ))}
      </div>
    </nav>

    <div
      class="gallery-container layout-content-container"
      data-gallery-lazy-config={JSON.stringify(lazyLoadRuntimeConfig)}
    >
      {categories.map(({ id, images, albums, testId, title }) => (
        <GallerySection
          sectionId={id}
          sectionTitle={title}
          images={images}
          albums={albums}
          sectionTestId={testId}
          columns={grid.columns}
          gap={grid.gap}
          placeholderEffectName={imageConfig.placeholderEffect}
        />
      ))}
    </div>
  </section>
</Layout>

<script>
  import { bootstrapDeferredMounts } from '../lib/deferred-mount-bootstrap';

  try {
    bootstrapDeferredMounts({
      containerSelector: '.gallery-container[data-gallery-lazy-config]',
      configDataKey: 'galleryLazyConfig',
      mountGroup: 'gallery-image',
    });
  } catch (e) {
    console.error('Failed to initialize gallery deferred loading:', e);
  }
</script>

<style>
  .photography-page {
    flex: 1;
    padding: var(--space-section-y) 0;
    width: 100%;
    box-sizing: border-box;
    --sticky-nav-padding-y: 0.75rem;
    --sticky-nav-row-height: 2rem;
    --sticky-nav-height: calc(
      var(--sticky-nav-row-height) + (var(--sticky-nav-padding-y) * 2)
    );
    --sticky-stack-offset: calc(
      var(--header-height) + var(--sticky-nav-height)
    );
    --section-anchor-scroll-margin: calc(
      var(--sticky-stack-offset) + var(--space-stack-sm)
    );
  }

  .hero-block {
    padding: clamp(0.75rem, 2vw, 1.25rem) var(--space-page-x);
    text-align: center;
  }

  .eyebrow-accent {
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  .title-accent {
    text-shadow: 0 3px 12px rgba(0, 0, 0, 0.35);
  }

  .meta-line {
    margin: 0 0 var(--space-stack-sm);
    font-size: 0.8125rem;
    color: var(--hero-text-light-muted);
    letter-spacing: 0.02em;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.35);
  }

  .page-description {
    margin: 0 auto;
    max-width: var(--measure-subhead);
    color: var(--hero-text-light-muted);
    font-size: 1rem;
    line-height: 1.55;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  }

  .sticky-nav {
    position: sticky;
    top: var(--header-height);
    z-index: 10;
    min-height: var(--sticky-nav-height);
    box-sizing: border-box;

    padding: var(--sticky-nav-padding-y) var(--space-page-x);
    /* Background and border removed - nav overlays content directly without mask */
  }

  .nav-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: var(--sticky-nav-row-height);
  }

  .nav-chip {
    display: inline-flex;
    align-items: center;
    min-height: var(--sticky-nav-row-height);
    box-sizing: border-box;
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--nav-chip-text);
    text-decoration: none;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--nav-chip-radius);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    transition: 
      background var(--motion-duration-sm) var(--motion-ease-smooth),
      transform var(--motion-duration-sm) var(--motion-ease-smooth);
  }

  .nav-chip:hover {
    background: var(--nav-chip-hover-bg);
    transform: translateY(-1px);
  }

  .nav-chip:focus-visible {
    outline: var(--focus-ring);
    outline-offset: 2px;
  }

  .gallery-container {
    padding-top: var(--space-stack-lg);
  }

  @media (max-width: 767px) {
    .hero-block {
      padding: 0.625rem 1rem 0.5rem;
    }

    .eyebrow-accent {
      font-size: 0.6875rem;
      letter-spacing: 0.14em;
    }

    .title-accent {
      margin-bottom: 0.5rem;
      font-size: clamp(2rem, 10.5vw, 2.5rem);
      line-height: 1.08;
    }

    .meta-line {
      font-size: 0.8125rem;
      margin-bottom: 0.5rem;
    }

    .page-description {
      font-size: 0.96rem;
      line-height: 1.6;
    }

    .sticky-nav {
      --sticky-nav-padding-y: 0.625rem;
      padding-inline: 1rem;
    }

    .nav-inner {
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: center;
      gap: 0.5rem;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x proximity;
    }

    .nav-inner::-webkit-scrollbar {
      display: none;
    }

    .nav-chip {
      flex-shrink: 0;
      padding: 0.375rem 0.8125rem;
      font-size: 0.8125rem;
      scroll-snap-align: start;
    }

    .gallery-container {
      padding-top: var(--space-stack-sm);
    }
  }
</style>
